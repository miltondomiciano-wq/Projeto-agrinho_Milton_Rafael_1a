                        <div class="text-emerald-300 mt-1 text-sm font-medium tracking-wider">MILHÕES DE HECTARES REGENERADOS</div>
                    </div>
                    <div class="text-center border border-white/10 rounded-3xl p-8">
                        <div id="stat-3" class="metric-value stat-number" data-target="18.7">0</div>
                        <div class="text-emerald-300 mt-1 text-sm font-medium tracking-wider">MILHÕES DE TONELADAS DE CO₂ SEQUESTRADAS</div>
                    </div>
                    <div class="text-center border border-white/10 rounded-3xl p-8">
                        <div id="stat-4" class="metric-value stat-number" data-target="31">0</div>
                        <div class="text-emerald-300 mt-1 text-sm font-medium tracking-wider">% DE AUMENTO MÉDIO NA RENDA</div>
                    </div>
                </div>
                
                <div class="mt-12 text-center">
                    <p class="max-w-md mx-auto text-emerald-200">Dados atualizados em tempo real pelo Sistema Nacional de Monitoramento da Agricultura Regenerativa (SNMAR)</p>
                </div>
            </div>
        </section>

        <!-- INTERAJA - QUIZ + CALCULADORA -->
        <section id="interaja" class="max-w-screen-2xl mx-auto px-8 py-20">
            <div class="text-center mb-12">
                <div class="inline-block px-6 py-1 rounded-3xl bg-emerald-100 text-emerald-700 text-xs font-extrabold tracking-[2px]">EXPERIÊNCIA INTERATIVA</div>
                <h2 class="section-header mt-3">Teste o futuro da sua fazenda</h2>
                <p class="max-w-lg mx-auto mt-3 text-lg text-slate-600">Responda o quiz e use nossa calculadora para descobrir o potencial de transformação da sua propriedade.</p>
            </div>
            
            <div class="grid lg:grid-cols-12 gap-8">
                
                <!-- QUIZ -->
                <div class="lg:col-span-7 bg-white border border-emerald-100 shadow-sm rounded-3xl p-9">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <span class="font-bold text-xl">Quiz: Qual é o seu nível de sustentabilidade?</span>
                        </div>
                        <div id="quiz-progress" class="text-xs font-mono bg-emerald-100 text-emerald-700 px-3 py-1 rounded-2xl font-bold">1/7</div>
                    </div>
                    
                    <div id="quiz-container">
                        <!-- Quiz content injected by JS -->
                    </div>
                    
                    <div class="flex justify-between items-center mt-8">
                        <button onclick="prevQuestion()" id="quiz-prev"
                                class="px-6 py-3 text-sm font-semibold text-slate-500 hover:text-slate-700 flex items-center gap-x-2 disabled:opacity-40" disabled>
                            <i class="fa-solid fa-arrow-left"></i> <span>Anterior</span>
                        </button>
                        
                        <button onclick="nextQuestion()" id="quiz-next"
                                class="px-8 py-3.5 rounded-2xl font-semibold bg-emerald-800 hover:bg-emerald-900 transition-colors text-white flex items-center gap-x-2 text-sm">
                            <span id="quiz-next-text">Próxima pergunta</span>
                        </button>
                    </div>
                </div>
                
                <!-- CALCULADORA -->
                <div class="lg:col-span-5 bg-emerald-900 text-white rounded-3xl p-9 flex flex-col">
                    <div class="mb-6">
                        <div class="font-bold text-2xl tracking-tight">Calculadora de Impacto</div>
                        <p class="text-emerald-200 text-sm mt-1">Descubra quanto você pode ganhar em produtividade e carbono</p>
                    </div>
                    
                    <div class="space-y-5 flex-1">
                        <div>
                            <label class="text-xs font-semibold tracking-wider text-emerald-300">ÁREA DA FAZENDA (hectares)</label>
                            <input type="range" id="area-range" min="50" max="5000" step="50" value="850" 
                                   class="w-full accent-emerald-400 mt-2" oninput="updateCalculator()">
                            <div class="flex justify-between text-xs mt-1">
                                <div>50 ha</div>
                                <div id="area-value" class="font-mono font-bold text-xl text-white">850</div>
                                <div>5.000 ha</div>
                            </div>
                        </div>
                        
                        <div>
                            <label class="text-xs font-semibold tracking-wider text-emerald-300">% DE ÁREA COM PRÁTICAS SUSTENTÁVEIS</label>
                            <input type="range" id="sust-range" min="0" max="100" step="5" value="35" 
                                   class="w-full accent-emerald-400 mt-2" oninput="updateCalculator()">
                            <div class="flex justify-between text-xs mt-1">
                                <div>0%</div>
                                <div id="sust-value" class="font-mono font-bold text-xl text-white">35%</div>
                                <div>100%</div>
                            </div>
                        </div>
                        
                        <div>
                            <label class="text-xs font-semibold tracking-wider text-emerald-300">PRINCIPAL ATIVIDADE</label>
                            <select id="atividade-select" onchange="updateCalculator()" 
                                    class="w-full mt-2 bg-emerald-800 border border-emerald-700 text-white rounded-2xl px-4 py-3 text-sm">
                                <option value="soja">Soja / Grãos</option>
                                <option value="milho">Milho</option>
                                <option value="pecuaria">Pecuária de Corte</option>
                                <option value="leite">Pecuária de Leite</option>
                                <option value="cafe">Café</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="mt-auto pt-8 border-t border-emerald-700">
                        <button onclick="calculateImpact()" 
                                class="w-full py-4 text-sm font-bold tracking-wider rounded-2xl bg-white text-emerald-900 hover:bg-emerald-100 active:scale-[0.985] transition flex justify-center items-center gap-x-2">
                            <i class="fa-solid fa-calculator"></i>
                            <span>CALCULAR MEU IMPACTO</span>
                        </button>
                        
                        <div id="calculator-results" class="hidden mt-6 text-sm space-y-3">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CASES DE SUCESSO -->
        <section class="max-w-screen-2xl mx-auto px-8 pb-20">
            <div class="flex items-end justify-between mb-8">
                <div>
                    <div class="font-bold tracking-widest text-emerald-600 text-sm">HISTÓRIAS REAIS</div>
                    <h3 class="text-4xl font-bold tracking-tighter">Quem já está colhendo os frutos</h3>
                </div>
                <a href="#" class="hidden md:flex items-center text-sm font-semibold text-emerald-700 hover:text-emerald-800">Ver todos os cases <i class="fa-solid fa-arrow-right ml-2"></i></a>
            </div>
            
            <div class="grid md:grid-cols-3 gap-6">
                <!-- Case 1 -->
                <div onclick="showCaseModal(0)" class="group cursor-pointer bg-white border border-emerald-100 overflow-hidden rounded-3xl agro-card">
                    <div class="h-52 bg-cover bg-center" style="background-image: url('https://picsum.photos/id/160/600/400')"></div>
                    <div class="p-7">
                        <div class="flex justify-between items-center">
                            <div>
                                <div class="font-bold">Fazenda Santa Rita</div>
                                <div class="text-xs text-emerald-700">Mato Grosso • 4.200 ha</div>
                            </div>
                            <div class="text-right">
                                <div class="text-emerald-600 font-mono text-sm font-bold">+142%</div>
                                <div class="text-[10px] -mt-0.5 text-emerald-700">produtividade</div>
                            </div>
                        </div>
                        <div class="text-xs mt-4 text-slate-500">“Passamos de 58 sacas/ha para 141 sacas/ha de soja em 4 anos com ILPF e bioinsumos.”</div>
                    </div>
                </div>
                
                <div onclick="showCaseModal(1)" class="group cursor-pointer bg-white border border-emerald-100 overflow-hidden rounded-3xl agro-card">
                    <div class="h-52 bg-cover bg-center" style="background-image: url('https://picsum.photos/id/251/600/400')"></div>
                    <div class="p-7">
                        <div class="flex justify-between items-center">
                            <div>
                                <div class="font-bold">Grupo São João</div>
                                <div class="text-xs text-emerald-700">Goiás • 12.800 ha</div>
                            </div>
                            <div class="text-right">
                                <div class="text-emerald-600 font-mono text-sm font-bold">-68%</div>
                                <div class="text-[10px] -mt-0.5 text-emerald-700">emissões de CO₂</div>
                            </div>
                        </div>
                        <div class="text-xs mt-4 text-slate-500">“Hoje somos carbono negativo. Exportamos créditos de carbono e aumentamos a margem em 41%.”</div>
                    </div>
                </div>
                
                <div onclick="showCaseModal(2)" class="group cursor-pointer bg-white border border-emerald-100 overflow-hidden rounded-3xl agro-card">
                    <div class="h-52 bg-cover bg-center" style="background-image: url('https://picsum.photos/id/292/600/400')"></div>
                    <div class="p-7">
                        <div class="flex justify-between items-center">
                            <div>
                                <div class="font-bold">Fazenda Veredas</div>
                                <div class="text-xs text-emerald-700">Minas Gerais • 890 ha</div>
                            </div>
                            <div class="text-right">
                                <div class="text-emerald-600 font-mono text-sm font-bold">+87%</div>
                                <div class="text-[10px] -mt-0.5 text-emerald-700">biodiversidade</div>
                            </div>
                        </div>
                        <div class="text-xs mt-4 text-slate-500">“Recuperamos nascentes, aumentamos abelhas e hoje vendemos mel orgânico premium junto com o café.”</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA FINAL -->
        <section class="max-w-screen-2xl mx-auto px-8 pb-16">
            <div class="bg-emerald-900 text-white rounded-[2.75rem] px-10 md:px-16 py-14 text-center md:text-left md:flex items-center gap-x-12">
                <div class="md:w-7/12">
                    <div class="text-emerald-300 font-bold tracking-widest text-xs mb-3">PRÓXIMO PASSO</div>
                    <h2 class="text-4xl md:text-5xl font-bold tracking-tighter">Pronto para transformar sua fazenda?</h2>
                    <p class="mt-4 text-emerald-100 max-w-md">Junte-se a mais de 47 mil produtores que já estão construindo o futuro sustentável do agro brasileiro.</p>
                </div>
                
                <div class="md:w-5/12 mt-8 md:mt-0">
                    <button onclick="joinMovement()" 
                            class="w-full md:w-auto px-10 py-4 bg-white hover:bg-emerald-50 active:scale-[0.985] transition-all text-emerald-900 font-extrabold tracking-wider rounded-3xl flex items-center justify-center gap-x-3 text-lg shadow-xl">
                        <span>QUERO FAZER PARTE DO AGROFORTE</span>
                    </button>
                    <div class="text-emerald-300 text-xs mt-4 tracking-wider">Compromisso gratuito • Resultados em 90 dias</div>
                </div>
            </div>
        </section>
    </main>

    <!-- FOOTER -->
    <footer class="bg-slate-900 text-white/70 text-sm pt-14 pb-9">
        <div class="max-w-screen-2xl mx-auto px-8">
            <div class="flex flex-col md:flex-row justify-between gap-y-12">
                <div>
                    <div class="flex items-center gap-x-3 mb-4">
                        <div class="w-9 h-9 bg-emerald-700 rounded-2xl flex items-center justify-center">
                            <span class="text-white font-black text-xl">AF</span>
                        </div>
                        <span class="font-bold text-3xl text-white tracking-tighter">AgroForte</span>
                    </div>
                    <div class="max-w-xs">Movimento nacional pela agricultura forte, produtiva e regenerativa.</div>
                    
                    <div class="flex gap-x-5 mt-6 text-xl">
                        <i class="fa-brands fa-instagram cursor-pointer hover:text-white"></i>
                        <i class="fa-brands fa-linkedin cursor-pointer hover:text-white"></i>
                        <i class="fa-brands fa-youtube cursor-pointer hover:text-white"></i>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 md:grid-cols-3 gap-x-16 gap-y-8 text-sm">
                    <div>
                        <div class="font-semibold text-white mb-4">Plataforma</div>
                        <div class="space-y-[7px]">
                            <div>Dashboard do Produtor</div>
                            <div>Certificação Regenerativa</div>
                            <div>Mercado de Carbono</div>
                        </div>
                    </div>
                    <div>
                        <div class="font-semibold text-white mb-4">Recursos</div>
                        <div class="space-y-[7px]">
                            <div>Guia de Boas Práticas</div>
                            <div>Calculadora de Carbono</div>
                            <div>Comunidade AgroForte</div>
                        </div>
                    </div>
                    <div>
                        <div class="font-semibold text-white mb-4">Sobre</div>
                        <div class="space-y-[7px]">
                            <div>Nossa Missão</div>
                            <div>Impacto 2030</div>
                            <div>Transparência</div>
                            <div>Contato</div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="border-t border-white/10 mt-14 pt-8 flex flex-col md:flex-row justify-between items-center text-xs">
                <div>© 2026 AgroForte • Todos os direitos reservados • Uma iniciativa do Brasil para o mundo</div>
                <div class="mt-3 md:mt-0">Feito com <span class="text-emerald-400">🌱</span> para um futuro sustentável</div>
            </div>
        </div>
    </footer>

    <!-- MODALS -->
    
    <!-- Tech Modal -->
    <div id="tech-modal" onclick="if (event.target.id === 'tech-modal') hideTechModal()" class="hidden fixed inset-0 bg-black/70 z-[100] flex items-center justify-center p-6">
        <div onclick="event.stopImmediatePropagation()" class="bg-white max-w-lg w-full rounded-3xl overflow-hidden modal">
            <div class="p-9" id="tech-modal-content">
                <!-- Dynamic content -->
            </div>
            <div class="px-9 pb-8">
                <button onclick="hideTechModal()" 
                        class="w-full py-3.5 rounded-2xl border font-semibold hover:bg-slate-50 transition">Fechar</button>
            </div>
        </div>
    </div>
    
    <!-- Case Modal -->
    <div id="case-modal" onclick="if (event.target.id === 'case-modal') hideCaseModal()" class="hidden fixed inset-0 bg-black/70 z-[100] flex items-center justify-center p-6">
        <div onclick="event.stopImmediatePropagation()" class="bg-white max-w-2xl w-full rounded-3xl overflow-hidden modal">
            <div id="case-modal-content" class="p-9">
                <!-- Dynamic -->
            </div>
            <div class="px-9 pb-9 flex gap-x-4">
                <button onclick="hideCaseModal()" class="flex-1 py-3.5 text-sm font-semibold border rounded-2xl hover:bg-slate-50">Fechar</button>
                <button onclick="contactProducer()" class="flex-1 py-3.5 text-sm font-semibold bg-emerald-800 text-white rounded-2xl">Falar com o produtor</button>
            </div>
        </div>
    </div>

    <!-- Success / Certificate Modal -->
    <div id="success-modal" onclick="if (event.target.id === 'success-modal') hideSuccessModal()" class="hidden fixed inset-0 bg-black/70 z-[110] flex items-center justify-center p-6">
        <div onclick="event.stopImmediatePropagation()" class="bg-white max-w-md w-full rounded-3xl p-9 modal text-center">
            <div class="mx-auto w-20 h-20 bg-emerald-100 text-emerald-700 flex items-center justify-center rounded-full mb-6">
                <i class="fa-solid fa-seedling text-5xl"></i>
            </div>
            <h3 class="font-bold text-3xl tracking-tight">Parabéns!</h3>
            <p id="success-message" class="mt-3 text-slate-600"></p>
            
            <div class="mt-8">
                <button onclick="hideSuccessModal()" 
                        class="px-10 py-3.5 bg-emerald-800 hover:bg-emerald-900 text-white font-bold text-sm tracking-wider rounded-3xl">ENTENDI</button>
            </div>
        </div>
    </div>

